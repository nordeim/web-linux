{
  "name": "ubuntuos-backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -b",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "eslint . --ext .ts",
    "docker:build": "docker build -t ubuntuos-terminal:latest .",
    "docker:test": "docker run --rm ubuntuos-terminal:latest echo 'Image OK'"
  },
  "dependencies": {
    "dockerode": "^4.0.12",
    "dotenv": "^16.6.1",
    "express": "^4.22.2",
    "express-rate-limit": "^7.5.1",
    "jose": "^5.10.0",
    "node-pty": "^1.1.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/dockerode": "^3.3.47",
    "@types/express": "^4.17.25",
    "@types/node": "^24.13.1",
    "@types/ws": "^8.18.1",
    "typescript": "~5.9.3",
    "vitest": "^4.1.8"
  }
}
